+				imageData[idx + 3] = (byte)255;
+			}
+		}
+	}
+
+	@Override
+	public void bindImage(RenderEngine engine) {
+		GL11.glBindTexture(GL11.GL_TEXTURE_2D, engine.getTexture("/terrain.png"));
